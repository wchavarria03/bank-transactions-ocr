# Local development (docker compose up)
SUPABASE_URL=http://localhost:3000
SUPABASE_KEY=local-dev
SUPABASE_ANON_KEY=local-dev
SUPABASE_JWT_SECRET=local-dev-secret
LEDGER_USER_ID=
ALLOWED_ORIGINS=*

# Production (Supabase cloud)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_KEY=<service-role-key>             (Settings → API Keys → Legacy → service_role)
# SUPABASE_ANON_KEY=<anon-key>                (Settings → API Keys → Legacy → anon)
# SUPABASE_JWT_SECRET=<jwt-secret>            (Settings → JWT Keys → JWT Secret)
# LEDGER_USER_ID=<your-supabase-user-uuid>    (Authentication → Users)
# ALLOWED_ORIGINS=https://yourapp.lovable.app
