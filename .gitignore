# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below if you use Go modules)
vendor/

# Go workspace file
go.work

# Runtime data (PDFs and extracted output are private/local)
data/input/*
data/output/*
!data/input/.gitkeep
!data/output/.gitkeep

# Environment variables (.envrc is committed; .env is not)
.env

# Built binary
bank-transactions-ocr
